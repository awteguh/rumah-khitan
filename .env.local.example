# =============================================================
#  CONTOH PENGATURAN RAHASIA (ENV)
#  1. Salin file ini menjadi ".env.local"
#  2. Isi nilainya dari dashboard Supabase Anda
#  3. JANGAN commit file .env.local ke git (sudah diabaikan)
# =============================================================

# --- Supabase (Settings > API di dashboard Supabase) ---
# Boleh dilihat publik (dikirim ke browser):
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...kunci-anon...

# RAHASIA — hanya dipakai di server, jangan beri awalan NEXT_PUBLIC:
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...kunci-service-role...

# --- Login dashboard /admin (buat sendiri, bebas) ---
ADMIN_USER=admin
ADMIN_PASSWORD=gantiDenganPasswordKuat
